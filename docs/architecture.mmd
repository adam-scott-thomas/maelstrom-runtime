---
title: Maelstrom Runtime v2.0.0 — Full Architecture
---
flowchart TB

    %% ── Styles ──
    classDef runtime fill:#0c1425,stroke:#60a5fa,color:#bfdbfe,stroke-width:3px
    classDef modstyle fill:#1e293b,stroke:#3b82f6,color:#e2e8f0,stroke-width:2px
    classDef stepstyle fill:#0f172a,stroke:#f59e0b,color:#fde68a,stroke-width:2px
    classDef statestyle fill:#1e3a5f,stroke:#38bdf8,color:#bae6fd,stroke-width:2px
    classDef typestyle fill:#064e3b,stroke:#34d399,color:#d1fae5,stroke-width:1px
    classDef toolstyle fill:#1e1b2e,stroke:#a78bfa,color:#ddd6fe,stroke-width:2px
    classDef tracestyle fill:#312e81,stroke:#818cf8,color:#c7d2fe,stroke-width:2px
    classDef docstyle fill:#3b1f2b,stroke:#f472b6,color:#fbcfe8,stroke-width:2px
    classDef extbound fill:#1c1917,stroke:#a8a29e,color:#e7e5e4,stroke-width:1px,stroke-dasharray:5 5
    classDef agentstyle fill:#1a2e1a,stroke:#4ade80,color:#bbf7d0,stroke-width:2px

    %% ══════════════════════════════════════════════
    %% EXTERNAL BOUNDARY
    %% ══════════════════════════════════════════════
    EXT_SPEC(("MaelstromSpec<br/>(from JSON)<br/><i>28 scenario files</i>"))
    EXT_CLI(("CLI<br/><i>python -m maelstrom run</i>"))

    %% ══════════════════════════════════════════════
    %% RUNTIME — sole orchestrator
    %% ══════════════════════════════════════════════
    RT["<b>MaelstromRuntime</b><br/><i>Deterministic simulation runtime</i><br/><i>run() → _execute_cycle(t) × T</i><br/><i>Owns: spec, rng, constraint_state,</i><br/><i>penalty_history, prev_regime, doctrine,</i><br/><i>prev_regret, trace_writer, doctrine_records</i>"]

    EXT_SPEC --> RT
    EXT_CLI -->|"__main__.py"| RT

    %% ══════════════════════════════════════════════
    %% OUTPUTS
    %% ══════════════════════════════════════════════
    subgraph OUTPUTS["Output Directory"]
        direction LR
        OUT_TRACE["trace.jsonl<br/><i>1 JSON per cycle, append-only</i>"]
        OUT_SUMMARY["summary.json<br/><i>regime dist, regret, switches</i>"]
        OUT_HUMAN["trace_human.md<br/><i>readable narrative</i>"]
        OUT_REPORT["report.md<br/><i>one-page run summary</i>"]
        OUT_DOCTRINE["doctrine_candidates.jsonl<br/><i>structured records</i>"]
        OUT_FEEDBACK["feedback_deltas.json<br/><i>bounded parameter adjustments</i>"]
        OUT_CSV["4 CSV files<br/><i>regimes, bypasses, vetoes, regret</i>"]
    end

    RT --> OUTPUTS

    %% ══════════════════════════════════════════════
    %% SPEC TYPES (spec.py)
    %% ══════════════════════════════════════════════
    subgraph SPEC["spec.py — Scenario Definitions"]
        direction LR
        SP_MSPEC["MaelstromSpec<br/><i>from_json(), to_dict()</i><br/><i>stressor_index(), regime_by_name()</i><br/><i>get_transition()</i>"]
        SP_TRANS["TransitionSpec<br/><i>source, target, A, W, α, β</i>"]
        SP_REGIME["RegimeSpec<br/><i>name, w[], u[]</i>"]
        SP_OVERLAY["OverlaySpec<br/><i>type, thresholds, phases, logic</i>"]
        SP_BYPASS["BypassSpec<br/><i>per-bypass latency_budget</i>"]
    end

    %% ══════════════════════════════════════════════
    %% UTILITY MODULES (utils.py)
    %% ══════════════════════════════════════════════
    subgraph UTILS["utils.py — Deterministic Primitives"]
        direction LR
        U_RNG["DeterministicRNG<br/><i>seeded, draw-counted</i><br/><i>noise(), state_snapshot()</i>"]
        U_ARGMAX["deterministic_argmax()<br/><i>tiebreak by REGIME_PRIORITY</i>"]
        U_HASH["hash_state()<br/><i>SHA-256 canonical JSON</i>"]
        U_CLAMP["clamp()"]
    end

    %% ══════════════════════════════════════════════
    %% 5 SPECIALIST AGENTS (agents.py)
    %% ══════════════════════════════════════════════
    subgraph AGENTS["agents.py — 5 Specialist Proposal Generators"]
        direction TB

        AG_KESTREL["Kestrel Adar<br/><i>Evaluate — clarity, risk</i><br/><i>3 proposals × 5 score dims</i>"]
        AG_DORIAN["Dorian Vale<br/><i>Generate — novelty, optionality</i><br/><i>3 proposals × 5 score dims</i>"]
        AG_HELENE["Helene Quatre<br/><i>Select — defensibility, obligation</i><br/><i>3 proposals × 5 score dims</i>"]
        AG_VANCE["Vance Calderon<br/><i>Execute — tempo, closure</i><br/><i>3 proposals × 5 score dims</i>"]
        AG_ISOLDE["Isolde Marek<br/><i>Reflect — coherence, blame</i><br/><i>3 proposals × 5 score dims</i><br/><i>regret_prev modulates novelty</i>"]

        AG_SCORING["REGIME_SCORE_WEIGHTS<br/><i>6 regimes × 5 dims = 30 weights</i><br/><i>score_proposal_for_regime()</i><br/><i>select_best_proposal()</i>"]
    end

    %% ══════════════════════════════════════════════
    %% FUNCTIONAL MODULES
    %% ══════════════════════════════════════════════
    subgraph MODULES["Functional Modules — Pure Functions"]
        direction TB

        MOD_STRESSORS["stressors.py<br/><i>interpolate_keyframes()</i><br/><i>compute_stressor_vector(spec, t)</i><br/><i>stressor_dict(spec, vec)</i>"]

        MOD_LEGALITY["legality.py<br/><i>deform_transition()</i><br/><i>deform_all(spec, S) → dict</i><br/><i>legality_summary()</i><br/><i>canonical_path_admissible()</i><br/><i>canonical_path_penalty()</i><br/><i>DeformedTransition dataclass</i>"]

        MOD_REGIMES["regimes.py<br/><i>P_r(t) = w_r·S(t) + u_r·C(t)</i><br/><i>compute_all_penalties()</i><br/><i>compute_gradients() — ΔP_r/Δt</i><br/><i>select_active_regime() — argmax + inertia</i><br/><i>regime_switch_trace() — decision metadata</i><br/><i>update_constraint_state() — C(t+1) with decay</i><br/><i>_resolve_inertia() — asymmetric out_of/into</i><br/><i>ConstraintState NamedTuple (6 fields)</i>"]

        MOD_OVERLAYS["overlays.py<br/><i>apply_overlays() — AND/OR veto gates</i><br/><i>any_identity_veto()</i><br/><i>any_coalition_veto()</i><br/><i>coalition_drag_level()</i><br/><i>VetoEvent + to_dict()</i>"]

        MOD_BYPASSES["bypasses.py<br/><i>check_bypass_eligibility()</i><br/><i>select_bypass() — penalty-saving based</i><br/><i>determine_execution_path()</i><br/><i>BYPASS_REPLACES — canonical sub-paths</i><br/><i>BypassEligibility (+ penalty_saving)</i><br/><i>BypassEvent + to_dict()</i>"]
    end

    %% ══════════════════════════════════════════════
    %% DOCTRINE SUBSYSTEM (doctrine/)
    %% ══════════════════════════════════════════════
    subgraph DOCTRINE["doctrine/ — Regret Engine + Counterfactual Archive"]
        direction TB

        DOC_STATE["DoctrineState<br/><i>archive_proposals() — score per regime</i><br/><i>compute_regret() — max(CF) - selected</i><br/><i>generate_doctrine_candidates()</i><br/><i>regret_summary()</i><br/><i>counterfactual_summary()</i>"]

        DOC_RECORDS["Records<br/><i>CounterfactualEntry — to_dict()</i><br/><i>DoctrineCandidate — to_dict()</i><br/><i>DoctrineRecord — to_dict()</i><br/><i>candidate_to_record()</i>"]

        subgraph DOC_TRIGGERS["Phase 9 Triggers"]
            direction LR
            DT1["regret_spike<br/><i>regret > 0.1</i>"]
            DT2["veto_gridlock<br/><i>veto_events > 0</i>"]
            DT3["gov_disallow_loop<br/><i>3+ consecutive disallows</i>"]
            DT4["low_conf_switch<br/><i>margin < 0.005</i>"]
            DT5["oscillation<br/><i>A-B-A-B-A-B × 6 cycles</i>"]
        end

        DOC_EVAL["doctrine/evaluate.py<br/><i>apply_deltas() — bounded spec modification</i><br/><i>run_scenario(), run_suite()</i><br/><i>compare_metrics() — promote rule</i><br/><i>evaluate_proposal()</i>"]

        DOC_STORE["doctrine/store.py<br/><i>Doctrine dataclass</i><br/><i>load_active(), save_active()</i><br/><i>load_proposals(), save_proposals()</i><br/><i>active.json, proposals.json</i>"]
    end

    %% ══════════════════════════════════════════════
    %% TRACE / FEEDBACK / EXPORT
    %% ══════════════════════════════════════════════
    subgraph TRACE_SYS["Trace, Feedback & Export"]
        direction TB

        TR_CYCLE["trace.py — CycleTrace<br/><i>22 fields per cycle</i><br/><i>stressors, constraints, legality,</i><br/><i>penalties, gradients, regime,</i><br/><i>proposals, vetoes, bypasses,</i><br/><i>path, action, counterfactuals,</i><br/><i>regret, doctrine, state_hash</i>"]

        TR_WRITER["TraceWriter<br/><i>append() → JSONL (crash-safe)</i><br/><i>write_summary()</i><br/><i>write_human_trace() → narrative</i><br/><i>write_report() → one-page summary</i>"]

        TR_FEEDBACK["feedback.py<br/><i>5 rules, all bounded:</i><br/><i>1. high regret → reduce W</i><br/><i>2. oscillation → increase inertia</i><br/><i>3. gov loops → reduce sensitivity</i><br/><i>4. veto gridlock → reduce W</i><br/><i>5. low-conf switches → wider window</i><br/><i>DELTA_BOUNDS per parameter</i>"]

        TR_EXPORT["export.py<br/><i>4 CSV files from trace.jsonl:</i><br/><i>regimes.csv, bypasses.csv,</i><br/><i>vetoes.csv, regret.csv</i>"]
    end

    %% ══════════════════════════════════════════════
    %% 13-STEP CYCLE LOOP
    %% ══════════════════════════════════════════════
    subgraph CYCLE["_execute_cycle(t) — Full Deliberation Loop"]
        direction TB

        C01["1. Update S(t)<br/><i>stressor vector from schedule</i>"]
        C02["2. Deform legality<br/><i>A' = A - α·S, W' = W + β·S</i>"]
        C03["3. Constraint state C(t)<br/><i>recency-weighted from prior cycle</i>"]
        C04["4. Penalties P_r(t) + gradients<br/><i>6 regimes, windowed ΔP/Δt</i>"]
        C05["5. Select regime r*(t)<br/><i>argmax + asymmetric inertia</i><br/><i>+ regime_switch_trace()</i>"]
        C06["6. Generate proposals<br/><i>5 specialists × 3 = 15 proposals</i>"]
        C07["7. Filter by overlays<br/><i>identity + coalition veto gates</i>"]
        C08["8. Bypass eligibility<br/><i>penalty-saving based selection</i>"]
        C09["9. Execution path<br/><i>canonical 5-phase or collapsed</i>"]
        C10["10. Select best per phase<br/><i>regime-weighted scoring</i>"]
        C11["11. Archive counterfactuals<br/><i>skipped + not-selected + vetoed</i>"]
        C12["12. Regret + doctrine<br/><i>compute_regret()</i><br/><i>generate_doctrine_candidates()</i>"]
        C13["13. Update state + log trace<br/><i>C(t+1), penalty_history,</i><br/><i>state_hash, CycleTrace</i>"]

        C01 --> C02 --> C03 --> C04 --> C05 --> C06 --> C07 --> C08 --> C09 --> C10 --> C11 --> C12 --> C13
    end

    %% ══════════════════════════════════════════════
    %% RUNTIME ↔ MODULE CONNECTIONS
    %% ══════════════════════════════════════════════

    RT -->|"for t in 1..total_cycles"| CYCLE
    RT -->|"per-cycle stressor lookup"| MOD_STRESSORS
    RT -->|"deform_all, admissibility"| MOD_LEGALITY
    RT -->|"penalties, gradients,<br/>regime, C(t+1), switch_trace"| MOD_REGIMES
    RT -->|"apply_overlays,<br/>identity/coalition veto,<br/>drag_level"| MOD_OVERLAYS
    RT -->|"eligibility, select,<br/>execution_path"| MOD_BYPASSES
    RT -->|"15 proposals per cycle,<br/>regime-weighted scoring"| AGENTS
    RT -->|"owns DoctrineState,<br/>regret, candidates"| DOCTRINE
    RT -->|"CycleTrace → JSONL,<br/>summary, reports"| TRACE_SYS
    TRACE_SYS --> OUTPUTS

    %% ══════════════════════════════════════════════
    %% CYCLE STATE
    %% ══════════════════════════════════════════════
    subgraph STATE["Cycle-to-Cycle State (owned by runtime)"]
        direction LR
        ST_C["constraint_state<br/><i>C(t) — ConstraintState</i><br/><i>6 floats, decay=0.8</i>"]
        ST_PH["penalty_history<br/><i>list[dict[str, float]]</i>"]
        ST_PR["prev_regime<br/><i>str | None</i>"]
        ST_REG["prev_regret<br/><i>float → isolde_marek novelty</i>"]
        ST_DOC["doctrine<br/><i>DoctrineState accumulator</i>"]
        ST_RNG["rng<br/><i>DeterministicRNG</i>"]
        ST_REC["_doctrine_records<br/><i>list[DoctrineRecord]</i>"]
    end

    RT ---|"reads + writes<br/>between cycles"| STATE

    %% ══════════════════════════════════════════════
    %% CANONICAL PHASES + BYPASSES
    %% ══════════════════════════════════════════════
    subgraph PHASES["Canonical 5-Phase Deliberation Loop"]
        direction LR
        P_EVAL["evaluate"]
        P_GEN["generate"]
        P_SEL["select"]
        P_EXEC["execute"]
        P_REFL["reflect"]
        P_EVAL --> P_GEN --> P_SEL --> P_EXEC --> P_REFL --> P_EVAL
    end

    subgraph BYPASSES_DEF["5 Bypass Paths (collapse phases)"]
        direction TB
        BP_IMP["Impulse<br/><i>E → X (survival)</i><br/><i>replaces E→G, G→S, S→X</i>"]
        BP_RUM["Rumination<br/><i>E → R (epistemic)</i><br/><i>replaces E→G, G→S, S→X, X→R</i>"]
        BP_MAN["Mania<br/><i>G → X (economic)</i><br/><i>replaces G→S, S→X</i>"]
        BP_GUI["Guilt<br/><i>S → R (moral, legal)</i><br/><i>replaces S→X, X→R</i>"]
        BP_OVL["Over-learning<br/><i>R → G (epistemic, economic)</i><br/><i>adds phases, no replacement</i>"]
    end

    MOD_BYPASSES -.-> BYPASSES_DEF
    BYPASSES_DEF -.->|"collapses canonical path<br/>when penalty_saving > 0"| PHASES
    AGENTS -.->|"1 specialist per phase<br/>3 proposals each"| PHASES

    %% ══════════════════════════════════════════════
    %% BACKWARD COMPAT
    %% ══════════════════════════════════════════════
    COMPAT["types.py<br/><i>backward-compat re-exports</i><br/><i>all types available at</i><br/><i>maelstrom.types.*</i>"]

    %% ══════════════════════════════════════════════
    %% LEGEND
    %% ══════════════════════════════════════════════
    subgraph LEGEND["Legend"]
        direction LR
        L1["──── data flow / ownership"]
        L2["- - - structural reference"]
        L3["Runtime is sole orchestrator.<br/>Modules are pure functions.<br/>No module imports another module.<br/>15 proposals × 50 cycles = 750 proposals.<br/>Deterministic: same seed → same trace."]
    end

    %% ── Apply styles ──
    class RT runtime
    class MOD_STRESSORS,MOD_LEGALITY,MOD_REGIMES,MOD_BYPASSES,MOD_OVERLAYS modstyle
    class C01,C02,C03,C04,C05,C06,C07,C08,C09,C10,C11,C12,C13 stepstyle
    class ST_C,ST_PH,ST_PR,ST_REG,ST_DOC,ST_RNG,ST_REC statestyle
    class SP_MSPEC,SP_TRANS,SP_REGIME,SP_OVERLAY,SP_BYPASS typestyle
    class U_RNG,U_ARGMAX,U_HASH,U_CLAMP modstyle
    class P_EVAL,P_GEN,P_SEL,P_EXEC,P_REFL stepstyle
    class BP_IMP,BP_RUM,BP_MAN,BP_GUI,BP_OVL modstyle
    class EXT_SPEC,EXT_CLI extbound
    class AG_KESTREL,AG_DORIAN,AG_HELENE,AG_VANCE,AG_ISOLDE,AG_SCORING agentstyle
    class TR_CYCLE,TR_WRITER tracestyle
    class TR_FEEDBACK,TR_EXPORT tracestyle
    class DOC_STATE,DOC_RECORDS,DOC_EVAL,DOC_STORE docstyle
    class DT1,DT2,DT3,DT4,DT5 docstyle
    class OUT_TRACE,OUT_SUMMARY,OUT_HUMAN,OUT_REPORT,OUT_DOCTRINE,OUT_FEEDBACK,OUT_CSV toolstyle
    class COMPAT typestyle
